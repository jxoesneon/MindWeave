# MindWeave Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# Supabase Configuration (Required)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# hCaptcha Configuration (Required for anonymous auth)
# ============================================
# Get your site key from https://dashboard.hcaptcha.com
HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# ============================================
# Firebase / Google Cloud API Keys
# ============================================
# From Firebase Console → Project Settings → General → Web API Key
FIREBASE_API_KEY_IOS=your-ios-api-key
FIREBASE_API_KEY_ANDROID=your-android-api-key
FIREBASE_API_KEY_WEB=your-web-api-key

# ============================================
# Google OAuth Client IDs (from Google Cloud Console)
# ============================================
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=your-web-client-secret
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ============================================
# Google Sign-In Configuration (Required for Google auth)
# ============================================
# From Google Cloud Console - OAuth 2.0 Client IDs
# Web Client ID (for Supabase auth)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS/macOS Client ID (for native sign-in)
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android Client ID (usually auto-configured via google-services.json)
# Note: Android uses the google-services.json file instead of env vars

# ============================================
# Feature Flags (Optional)
# ============================================
# Set to 'true' to enable CAPTCHA for anonymous auth
ENABLE_CAPTCHA=true

# Set to 'true' to enable Google Sign-In
ENABLE_GOOGLE_SIGNIN=true

# Set to 'true' for development mode (skips some checks)
DEV_MODE=false

# ============================================
# PostHog Analytics (Optional)
# ============================================
# POSTHOG_API_KEY=your_posthog_api_key
# POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# RevenueCat/Payment Configuration (Optional)
# ============================================
# REVENUECAT_API_KEY=your-revenuecat-api-key
# REVENUECAT_GOOGLE_KEY=your-google-key
# REVENUECAT_STRIPE_KEY=your-stripe-key
